# ──── Ping Backend – Environment Variables ────
# Copy this file to .env and fill in your values.
# The server reads these on startup via dotenv.

# ──── Server ────
# Port the HTTP/WebSocket server listens on
PORT=3000

# ──── Database ────
# Absolute or relative (to backend/) path for the SQLite database file.
# The file is created automatically if it does not exist.
# Default: ./ping.db  (inside the backend directory)
DB_PATH=./ping.db

# ──── CORS ────
# Comma-separated list of allowed frontend origins.
# Add your production frontend URL here when deploying.
CORS_ORIGINS=http://localhost:4200,http://localhost:4000,http://192.168.0.1:4200
